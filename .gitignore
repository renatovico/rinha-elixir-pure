# The directory Mix will write compiled artifacts to.
/_build/

# If you run "mix test --cover", coverage assets end up here.
/cover/

# The directory Mix downloads your dependencies sources to.
/deps/

# Where third-party dependencies like ExDoc output generated docs.
/doc/

# Temporary files, for example, from tests.
/tmp/

# If the VM crashes, it generates a dump, let's ignore it too.
erl_crash.dump

# Also ignore archive artifacts (built via "mix archive.build").
*.ez

# Ignore package tarball (built via "mix hex.build").
rinha-*.tar

# Brute-force oracle binary (~94 MB) used only by `mix rinha.bench`.
# Rebuilt via `make preprocess` from priv/resources/references.json.gz.
/priv/references_v2.bin

# IVF index (~94 MB) is required at runtime, so we DO track it.
# Rebuild via `make ivf-index`.
# /priv/ivf_index.bin   (intentionally NOT ignored)

# Source dataset (~48 MB) — pulled from the official Rinha 2026 repo;
# not tracked here.
/priv/resources/references.json.gz
